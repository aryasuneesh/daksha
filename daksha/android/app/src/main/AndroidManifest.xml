<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- INTERNET is used only once: to download the Gemma 4 model during
         first-launch onboarding.  All inference runs fully on-device. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Required by background_downloader foreground service (API 28+).
         Without FOREGROUND_SERVICE the OS refuses to elevate the WorkManager
         job to a foreground service, leaving it subject to the 10-min
         background job timeout — fatal for a 3.65 GB model download. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Android 14+ (API 34) requires a typed foreground-service permission
         that matches the service's foregroundServiceType attribute.
         background_downloader declares type="dataSync", so we must grant
         FOREGROUND_SERVICE_DATA_SYNC. Without this the foreground service
         throws a SecurityException on Pixel 9 Pro XL (Android 15). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Android 13+ (API 33) requires runtime permission to post notifications.
         background_downloader shows a download progress notification, so we
         declare it here; we request it at runtime in ModelSetupScreen. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="Daksha"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:fullBackupContent="@xml/no_backup"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:usesCleartextTraffic="false">
        <activity
            android:name="in.aryasuneesh.daksha.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Bundle the ML Kit Latin text-recognition model in the APK so OCR
             works fully offline (no network access required at runtime). -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="ocr" />

        <!-- Required by image_cropper (uCrop library). Must be declared
             explicitly — uCrop activities are not auto-merged. -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Override WorkManager's SystemForegroundService to add the dataSync
             foreground-service type required on Android 14+ (API 34+).
             WorkManager's own library manifest declares this service WITHOUT
             a foregroundServiceType attribute.  On Android 14+, starting a
             foreground service whose type is not declared raises a
             ForegroundServiceStartNotAllowedException.  The tools:replace
             attribute tells AGP's manifest merger to use THIS declaration
             instead of WorkManager's, adding the required type so that
             background_downloader can promote the download job to a foreground
             service (no timeout) when Config.runInForeground is set. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:replace="android:foregroundServiceType" />
    </application>
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
